{
  "name": "playwright-ts-dulux",
  "version": "1.0.0",
  "description": "Playwright + TypeScript end-to-end tests for dulux.co.uk",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:smoke": "playwright test --grep @smoke",
    "test:desktop": "playwright test --project=desktop-chrome",
    "test:mobile": "playwright test --project=mobile-chrome",
    "test:api": "playwright test --project=api",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/magdaU/playwright-ts-dulux.git"
  },
  "keywords": [
    "playwright",
    "typescript",
    "e2e",
    "dulux"
  ],
  "author": "Magdalena",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/magdaU/playwright-ts-dulux/issues"
  },
  "homepage": "https://github.com/magdaU/playwright-ts-dulux#readme",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "allure-commandline": "^2.42.0",
    "allure-playwright": "^3.9.0",
    "typescript": "^6.0.3"
  }
}
